:date_cases_Imputed rdf:type owl:AnnotationProperty .
:date_cases_Imputed rdfs:subClassOf terms:date ;
	rdfs:label "imputed date of infection"@en ;
	skos:prefLabel "imputed date of infection"@en ;  
	skos:altLabel "date_cases_Imputed"@en ;
	skos:altLabel "date cases Imputed"@en . 


